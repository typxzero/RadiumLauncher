<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RadiumLauncher.Views.ConfirmationWindow"
        Title="Confirm"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="BorderOnly"
        Background="#101010"
        Width="350"
        Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Panel>
        <Border BorderBrush="#2D2D2D" BorderThickness="1" ZIndex="100" IsHitTestVisible="False" />
        <Panel IsHitTestVisible="False" ClipToBounds="False">
            <Border Background="#000000"
                    Width="450" Height="450"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="-250,-350,0,0"
                    CornerRadius="450"
                    Opacity="0.8">
                <Border.Effect>
                    <BlurEffect Radius="150" />
                </Border.Effect>
            </Border>
            <Border Background="#000000"
                    Width="350" Height="350"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-300,-200,0"
                    CornerRadius="350"
                    Opacity="0.65">
                <Border.Effect>
                    <BlurEffect Radius="160" />
                </Border.Effect>
            </Border>
            <Border x:Name="HomeBackgroundLayer"
                    Background="#4424d8ff"
                    Width="500" Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,-200"
                    CornerRadius="300"
                    Opacity="0.45">
                <Border.Effect>
                    <BlurEffect Radius="170" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
            </Border>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="600"
                    Height="350"
                    Background="#0000002f"
                    CornerRadius="0"
                    Opacity="0.4">
                <Border.Effect>
                    <BlurEffect Radius="100" />
                </Border.Effect>
            </Border>
            <Panel IsHitTestVisible="False" ClipToBounds="False">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,-250,0,0"
                        Width="250"
                        Height="250"
                        CornerRadius="200"
                        Background="#0df904"
                        Opacity="0.6">
                    <Border.Effect>
                        <BlurEffect Radius="500" />
                    </Border.Effect>
                </Border>
            </Panel>
        </Panel>
        <Grid RowDefinitions="40, *, 60">
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    BorderBrush="#2D2D2D"
                    BorderThickness="0,0,0,1"
                    Padding="10,0"
                    Background="Transparent"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Image Width="18" Height="18" Source="/Assets/radium-icon.png" />
                        <TextBlock x:Name="WindowTitle" Text="Confirmation" Foreground="White" VerticalAlignment="Center" FontSize="11" FontWeight="Medium" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="#888888"
                            FontSize="14"
                            Padding="8,4"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="0" Margin="20, 60, 20, 60" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="MessageText" Text="Message Content"
                           Foreground="#CCCCCC"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,0,20,10">
                <Button x:Name="SecondaryButton"
                        Click="SecondaryButton_Click"
                        Width="120"
                        Height="34"
                        Content="No"
                        Background="#2D2D2D"
                        Foreground="White"
                        CornerRadius="6"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center" />
                <Button x:Name="PrimaryButton"
                        Click="PrimaryButton_Click"
                        Width="120"
                        Height="34"
                        Content="Yes"
                        Background="#24d81e"
                        Foreground="Black"
                        CornerRadius="6"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center" />
            </StackPanel>
        </Grid>
    </Panel>
</Window>
