<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RadiumLauncher.ViewModels"
        xmlns:m="using:RadiumLauncher.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RadiumLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowDecorations="BorderOnly"
        Icon="/Assets/radium-icon.png"
        Title="RadiumLauncher"
        Background="#000000"
        Width="800"
        Height="450"
        CanResize="True"
        WindowStartupLocation="CenterScreen">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.MainAction">
            <Setter Property="Height" Value="60" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.MainAction:pointerover">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#000000" />
        </Style>

        <Style Selector="Button.Ready">
            <Setter Property="Background" Value="#24d81e" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="CornerRadius" Value="15 0 0 15" />
        </Style>
        <Style Selector="Button.Ready:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0be004" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="CornerRadius" Value="15 0 0 15" />
        </Style>

        <Style Selector="Button.Download">
            <Setter Property="Background" Value="#209dfc" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="CornerRadius" Value="15" />
        </Style>
        <Style Selector="Button.Download:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1a8cdb" />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style Selector="Button.Unavailable">
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style Selector="Button.Stop">
            <Setter Property="Background" Value="#FF3B30" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="15" />
        </Style>
        <Style Selector="Button.Stop:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E03126" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="DropDownButton.SplitPlay">
            <Setter Property="Background" Value="#24d81e" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Height" Value="60" />
            <Setter Property="CornerRadius" Value="0 15 15 0" />
            <Setter Property="BorderThickness" Value="1,0,0,0" />
            <Setter Property="BorderBrush" Value="#22000000" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Background="Transparent"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          CornerRadius="{TemplateBinding CornerRadius}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="DropDownButton.SplitPlay:pointerover /template/ Border#RootBorder">
            <Setter Property="Background" Value="#0be004" />
        </Style>

        <Style Selector="Button.Config">
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.Config:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#111111" />
        </Style>

        <Style Selector="ProgressBar.BlueProgress">
            <Setter Property="Height" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#0df904" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
        </Style>

        <Style Selector="Button.ImageButton">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        </Style>

        <Style Selector="ItemsControl#CommunityMediaItemsControl > ContentPresenter:pointerover">
            <Setter Property="ZIndex" Value="10" />
        </Style>

        <Style Selector="ItemsControl#CommunityMediaItemsControl > ContentPresenter:pointerover Button.ImageButton">
            <Setter Property="RenderTransform" Value="scale(1.08)" />
        </Style>

        <Style Selector="ItemsControl#CommunityMediaItemsControl > ContentPresenter:pointerover Border#GradientOverlay">
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style Selector="ItemsControl#CommunityMediaItemsControl > ContentPresenter:pointerover Border#TextOverlay">
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style
            Selector="ItemsControl#CommunityMediaItemsControl > ContentPresenter:pointerover Button.ImageButton /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ItemsControl#CommunityMediaItemsControl > ContentPresenter:pointerover Button.ImageButton">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.InvisibleClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.ImageCloseButton">
            <Setter Property="Background" Value="Black" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.ImageCloseButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Black" />
            <Setter Property="Opacity" Value="0.7" />
        </Style>

        <Style Selector="Border.PhotoViewerOverlay">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.PhotoViewerOverlay.Visible">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>
    </Window.Styles>

    <Panel>
        <Grid ZIndex="200" IsHitTestVisible="True">
            <Border VerticalAlignment="Top" Height="4" Cursor="SizeNorthSouth"
                    Background="Transparent" PointerPressed="ResizeTop_PointerPressed" />
            <Border VerticalAlignment="Bottom" Height="4" Cursor="SizeNorthSouth"
                    Background="Transparent" PointerPressed="ResizeBottom_PointerPressed" />
            <Border HorizontalAlignment="Left" Width="4" Cursor="SizeWestEast"
                    Background="Transparent" PointerPressed="ResizeLeft_PointerPressed" />
            <Border HorizontalAlignment="Right" Width="4" Cursor="SizeWestEast"
                    Background="Transparent" PointerPressed="ResizeRight_PointerPressed" />
            <Border Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Cursor="TopLeftCorner" Background="Transparent"
                    PointerPressed="ResizeTopLeft_PointerPressed" />
            <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Cursor="TopRightCorner" Background="Transparent"
                    PointerPressed="ResizeTopRight_PointerPressed" />
            <Border Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Cursor="BottomLeftCorner" Background="Transparent"
                    PointerPressed="ResizeBottomLeft_PointerPressed" />
            <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Cursor="BottomRightCorner" Background="Transparent"
                    PointerPressed="ResizeBottomRight_PointerPressed" />
        </Grid>

        <Border BorderBrush="#2D2D2D" BorderThickness="1" ZIndex="100" IsHitTestVisible="False" />

        <Panel IsHitTestVisible="False" ClipToBounds="False">
            <Border Background="#000000"
                    Width="900" Height="900"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="-250,-350,0,0"
                    CornerRadius="450"
                    Opacity="0.8">
                <Border.Effect>
                    <BlurEffect Radius="150" />
                </Border.Effect>
            </Border>
            <Border Background="#000000"
                    Width="700" Height="700"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-300,-200,0"
                    CornerRadius="350"
                    Opacity="0.65">
                <Border.Effect>
                    <BlurEffect Radius="160" />
                </Border.Effect>
            </Border>
            <Border x:Name="HomeBackgroundLayer"
                    Background="#4424d8ff"
                    Width="1000" Height="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,-200"
                    CornerRadius="300"
                    Opacity="0.45">
                <Border.Effect>
                    <BlurEffect Radius="170" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
            </Border>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="1200"
                    Height="700"
                    Background="#0000002f"
                    CornerRadius="0"
                    Opacity="0.4">
                <Border.Effect>
                    <BlurEffect Radius="100" />
                </Border.Effect>
            </Border>
        </Panel>

        <Panel IsHitTestVisible="False" ClipToBounds="False">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,-250,0,0"
                    Width="400"
                    Height="400"
                    CornerRadius="200"
                    Background="#0df904"
                    Opacity="0.6">
                <Border.Effect>
                    <BlurEffect Radius="500" />
                </Border.Effect>
            </Border>
        </Panel>

        <Grid RowDefinitions="50, *">
            <Border
                Grid.Row="0"
                x:Name="TitleBar"
                Background="Transparent"
                BorderBrush="#2D2D2D"
                Padding="10,0"
                BorderThickness="0, 0, 0, 1"
                PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Image Width="24" Height="24" Source="/Assets/radium-icon.png" />
                        <Image Width="128" Height="24" Source="/Assets/radium-logo.png" Stretch="Uniform" />
                        <TextBlock Text="Launcher"
                                   Foreground="White"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"
                                   FontFamily="Arial"
                                   LetterSpacing="1" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Content="Update"
                            Background="Transparent"
                            Foreground="#888888"
                            Padding="8,4"
                            IsVisible="{Binding ShowUpdateButton}"
                            Command="{Binding OpenUpdateCommand}" />

                        <Button Content="-"
                                Background="Transparent"
                                Foreground="#888888"
                                Padding="8,4"
                                Click="MinimizeButton_Click" />

                        <Button Content="✕"
                                x:Name="CloseButton"
                                Background="Transparent"
                                Foreground="#888888"
                                Padding="10,4"
                                CornerRadius="4"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="ContentScrollViewer" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20" Spacing="30">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <Button x:Name="HomeTabButton"
                                Content="Home"
                                Width="120"
                                Height="40"
                                Background="#24d81e"
                                Foreground="Black"
                                FontWeight="SemiBold"
                                CornerRadius="12"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="HomeTabButton_Click" />
                        <Button x:Name="CreditsTabButton"
                                Content="Credits"
                                Width="120"
                                Height="40"
                                Background="#000000"
                                Foreground="#CCCCCC"
                                FontWeight="SemiBold"
                                CornerRadius="12"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="CreditsTabButton_Click" />
                    </StackPanel>

                    <StackPanel x:Name="HomeTabPanel" Spacing="30">
                        <StackPanel Spacing="20">
                        <Grid Width="300" HorizontalAlignment="Center" x:Name="HomeLogoGrid" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <Image Source="{Binding MainLogo, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                   Width="300" HorizontalAlignment="Center" />
                        </Grid>

                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">

                                <Panel Width="270">
                                    <StackPanel Orientation="Horizontal"
                                                IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.Ready}}">
                                        <Button Classes="MainAction Ready" Width="165" Click="MainButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="15"
                                                        HorizontalAlignment="Center">
                                                <Path Fill="Black" Data="M 0 0 L 15 10 L 0 20 Z" Width="15" Height="20"
                                                      Stretch="Fill" VerticalAlignment="Center" />
                                                <TextBlock Text="PLAY" Foreground="Black" FontWeight="Bold"
                                                           FontSize="20" VerticalAlignment="Center" LetterSpacing="2" />
                                            </StackPanel>
                                        </Button>
                                        <DropDownButton Classes="SplitPlay" Width="105">
                                            <DropDownButton.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                    <MenuItem Header="Screen" Command="{Binding SetLaunchModeCommand}"
                                                              CommandParameter="Screen" />
                                                    <MenuItem Header="VR" Command="{Binding SetLaunchModeCommand}"
                                                              CommandParameter="VR" />
                                                </MenuFlyout>
                                            </DropDownButton.Flyout>
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Center">
                                                <Image Source="/Assets/monitor.png" Width="15" Height="15"
                                                       IsVisible="{Binding ScreenIconVisible}" />
                                                <Image Source="/Assets/vr.png" Width="15" Height="15"
                                                       IsVisible="{Binding VrIconVisible}" />
                                                <TextBlock Text="{Binding SelectedLaunchMode}" Foreground="Black"
                                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                                           FontSize="14" />
                                                <Path Data="M0,0 L5,5 L10,0 Z" Fill="Black" Width="8" Height="4"
                                                      Stretch="Fill" VerticalAlignment="Center" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </DropDownButton>
                                    </StackPanel>

                                    <Button Classes="MainAction Download" Width="270"
                                            IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.NeedsDownload}}"
                                            Click="MainButton_Click"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="DOWNLOAD" Foreground="Black" FontWeight="Bold" FontSize="20"
                                                   VerticalAlignment="Center" LetterSpacing="2" />
                                    </Button>

                                    <Button Classes="MainAction Download" Width="270"
                                            IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.NeedsUpdate}}"
                                            Click="MainButton_Click"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="UPDATE" Foreground="Black" FontWeight="Bold" FontSize="20"
                                                   VerticalAlignment="Center" LetterSpacing="2" />
                                    </Button>

                                    <Button Classes="MainAction Download" Width="270"
                                            IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.NeedsPatching}}"
                                            Click="MainButton_Click"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="PATCH" Foreground="Black" FontWeight="Bold" FontSize="20"
                                                   VerticalAlignment="Center" LetterSpacing="2" />
                                    </Button>

                                    <Button Classes="MainAction Unavailable" Width="270"
                                            IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.Unavailable}}"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="UNAVAILABLE" Foreground="#666666" FontWeight="Bold"
                                                   FontSize="20" VerticalAlignment="Center" LetterSpacing="2" />
                                    </Button>

                                    <Button Classes="MainAction Stop" Width="270"
                                            IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.Running}}"
                                            Click="MainButton_Click"
                                            HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                            <Rectangle Fill="White" Width="18" Height="18" VerticalAlignment="Center" />
                                            <TextBlock Text="STOP" Foreground="White" FontWeight="Bold" FontSize="20"
                                                       VerticalAlignment="Center" LetterSpacing="2" />
                                        </StackPanel>
                                    </Button>

                                    <Grid Width="270" Height="60"
                                          IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.Downloading}}">
                                        <Border Background="#000000" CornerRadius="15" />
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="DOWNLOADING" Foreground="#666666" FontWeight="Bold"
                                                       FontSize="16" HorizontalAlignment="Center" LetterSpacing="1" />
                                            <TextBlock Text="{Binding ProgressDetails}" Foreground="#444444"
                                                       FontSize="10" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding EtaText}" Foreground="#888888"
                                                       FontSize="10" HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <ProgressBar Classes="BlueProgress" Value="{Binding DownloadProgress}"
                                                     Minimum="0" Maximum="100" />
                                    </Grid>

                                    <Grid Width="270" Height="60"
                                          IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.Verifying}}">
                                        <Border Background="#000000" CornerRadius="15" />
                                        <TextBlock Text="VERIFYING" Foreground="#666666" FontWeight="Bold"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" LetterSpacing="1" />
                                        <ProgressBar Classes="BlueProgress" IsIndeterminate="True" />
                                    </Grid>

                                    <Grid Width="270" Height="60"
                                          IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.Extracting}}">
                                        <Border Background="#000000" CornerRadius="15" />
                                        <TextBlock Text="EXTRACTING" Foreground="#666666" FontWeight="Bold"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" LetterSpacing="1" />
                                        <ProgressBar Classes="BlueProgress" IsIndeterminate="True" />
                                    </Grid>

                                    <Grid Width="270" Height="60"
                                          IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:LauncherState.Patching}}">
                                        <Border Background="#000000" CornerRadius="15" />
                                        <TextBlock Text="PATCHING" Foreground="#666666" FontWeight="Bold" FontSize="16"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   LetterSpacing="1" />
                                        <ProgressBar Classes="BlueProgress" IsIndeterminate="True" />
                                    </Grid>
                                </Panel>

                                <Button Classes="Config" Click="ConfigButton_Click">
                                    <Path Fill="White"
                                          Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.35 19.43,11.03L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.52,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.03C4.53,11.35 4.5,12.33 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.35 8.52,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.48,18.67 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                          Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Opacity="0.8">
                                <Panel Width="16" Height="16">
                                    <Image Source="{Binding OSLogo, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                           IsHitTestVisible="False" Width="16" Height="16" />
                                    <Border Background="White" Width="16" Height="16">
                                        <Border.OpacityMask>
                                            <ImageBrush
                                                Source="{Binding OSLogo, FallbackValue={x:Null}, TargetNullValue={x:Null}}" />
                                        </Border.OpacityMask>
                                    </Border>
                                </Panel>
                                <TextBlock Text="{Binding OperatingSystemName}" Foreground="White" FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="•" Foreground="#666666" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding OsVersion}" Foreground="#AAAAAA" FontSize="10"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Spacing="12">
                                <TextBlock Text="Announcements" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                           Margin="10,0,0,0" />
                                <Border Background="#000000" CornerRadius="15" Padding="12">
                                    <ItemsControl ItemsSource="{Binding Announcements}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#DDDDDD"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="15">
                        <TextBlock Text="Community Media" Foreground="White" FontSize="18" FontWeight="SemiBold"
                                   Margin="10,0,0,0" />
                        <ItemsControl ItemsSource="{Binding CommunityMediaItems}" x:Name="CommunityMediaItemsControl"
                                      ClipToBounds="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" ClipToBounds="False" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="m:FeedItem">
                                    <Button Padding="0" Margin="5" Background="Transparent" BorderThickness="0"
                                            Classes="ImageButton"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).MaximizePhotoCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}">
                                        <Border Name="ImageRoot" CornerRadius="12" ClipToBounds="True"
                                                Background="#000000" Height="140">
                                            <Panel>
                                                <Image
                                                    Source="{Binding Bitmap, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                    Stretch="UniformToFill" />
                                                <ProgressBar Classes="BlueProgress"
                                                             IsIndeterminate="True"
                                                             IsVisible="{Binding Bitmap, Converter={x:Static ObjectConverters.IsNull}}"
                                                             VerticalAlignment="Bottom" />
                                                <Border Name="GradientOverlay" VerticalAlignment="Bottom" Height="80">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                                        </Transitions>
                                                    </Border.Transitions>
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                            <GradientStop Color="#00000000" Offset="0" />
                                                            <GradientStop Color="#CC000000" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>

                                                <Border Name="TextOverlay" VerticalAlignment="Bottom" Padding="10">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                                        </Transitions>
                                                    </Border.Transitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding RoomName, FallbackValue=''}"
                                                                   Foreground="White"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   IsVisible="{Binding RoomName, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}"
                                                                   Opacity="0.9">
                                                        </TextBlock>

                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Border Width="24" Height="24" CornerRadius="12"
                                                                    ClipToBounds="True">
                                                                <Image
                                                                    Source="{Binding ProfileBitmap, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    Stretch="UniformToFill" />
                                                            </Border>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="@" Foreground="White" FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           VerticalAlignment="Center">
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Username, FallbackValue=''}"
                                                                           Foreground="White"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           VerticalAlignment="Center">
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Panel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            <StackPanel x:Name="CreditsTabPanel" Spacing="20" IsVisible="False">
                <StackPanel Spacing="12">
                    <TextBlock Text="Credits" Foreground="White" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="A fanmade Radium launcher made by typxzero."
                               Foreground="#AAAAAA" FontSize="15" TextWrapping="Wrap" MaxWidth="900" />
                </StackPanel>

                <Border Background="#000000" CornerRadius="18" Padding="20">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Development" Foreground="White" FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="typxzero — Core launcher logic, update system, and game integration."
                                       Foreground="#CCCCCC" FontSize="14" TextWrapping="Wrap" />
                            <TextBlock Text="Hollotone — Menu Music (Production), v1.1.0 feature additions and general debugging"
                                       Foreground="#CCCCCC" FontSize="14" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
        </Grid>

        <Border IsVisible="{Binding ShowUpdatePopup}" Background="#AA000000" ZIndex="600">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="#111111" CornerRadius="12" Padding="20" Width="420">
                    <StackPanel Spacing="12">
                        <TextBlock Text="A new launcher version is available" Foreground="White" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="Version: {Binding LatestVersion}" Foreground="#CCCCCC" />
                        <TextBlock Text="Would you like to open the release page to update now?" Foreground="#AAAAAA" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Background="#24d81e" Foreground="Black" Width="90" Command="{Binding OpenUpdateCommand}">Update</Button>
                            <Button Background="#000000" Foreground="#CCCCCC" Width="90" Command="{Binding DismissUpdateCommand}">No</Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Classes="PhotoViewerOverlay" Classes.Visible="{Binding IsPhotoMaximized}" Background="Black">
            <Panel>
                <Image Source="{Binding MaximizedPhoto.Bitmap, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                       Stretch="UniformToFill" Opacity="0.6">
                    <Image.Effect>
                        <BlurEffect Radius="50" />
                    </Image.Effect>
                </Image>

                <ProgressBar Classes="BlueProgress"
                             IsIndeterminate="True"
                             IsVisible="{Binding MaximizedPhoto.LargeBitmap, Converter={x:Static ObjectConverters.IsNull}, FallbackValue=False, TargetNullValue=True}"
                             VerticalAlignment="Bottom"
                             ZIndex="10" />

                <Button Classes="InvisibleClose" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0"
                        Command="{Binding CloseMaximizedPhotoCommand}" />

                <Grid Margin="40">
                    <Border CornerRadius="12" ClipToBounds="True" Background="#000000" BoxShadow="0 10 40 5 #AA000000"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Panel>
                            <Image
                                Source="{Binding MaximizedPhoto.LargeBitmap, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                Stretch="Uniform" MaxWidth="1280" MaxHeight="720" />

                            <Button Classes="ImageCloseButton" Content="✕" FontSize="18" Foreground="White"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15"
                                    Command="{Binding CloseMaximizedPhotoCommand}" />

                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom" Margin="15"
                                        IsVisible="{Binding MaximizedPhoto.LargeBitmap, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}">
                                <Border Width="48" Height="48" CornerRadius="24" ClipToBounds="True">
                                    <Image
                                        Source="{Binding MaximizedPhoto.ProfileBitmap, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                        Stretch="UniformToFill" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        Text="{Binding MaximizedPhoto.RoomName, FallbackValue='', TargetNullValue=''}"
                                        Foreground="White"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        IsVisible="{Binding MaximizedPhoto.RoomName, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}">
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="@" Foreground="White"
                                                   FontSize="{Binding MaximizedPhoto.RoomName, Converter={StaticResource RoomNameToFontSizeConverter}, ConverterParameter=14, FallbackValue=14, TargetNullValue=14}"
                                                   FontWeight="SemiBold">
                                        </TextBlock>
                                        <TextBlock
                                            Text="{Binding MaximizedPhoto.Username, FallbackValue='', TargetNullValue=''}"
                                            Foreground="White"
                                            FontSize="{Binding MaximizedPhoto.RoomName, Converter={StaticResource RoomNameToFontSizeConverter}, ConverterParameter=14, FallbackValue=14, TargetNullValue=14}"
                                            FontWeight="SemiBold">
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Panel>
                    </Border>
                </Grid>
            </Panel>
        </Border>
    </Panel>
</Window>