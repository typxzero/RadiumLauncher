<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
        x:Class="RadiumLauncher.Views.ConfigurationWindow"
        Title="Configuration"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="BorderOnly"
        Background="#101010"
        Width="400"
        Height="300"
        WindowStartupLocation="CenterOwner">

    <Panel>
        <Border BorderBrush="#2D2D2D" BorderThickness="1" ZIndex="100" IsHitTestVisible="False" />
        <Panel IsHitTestVisible="False" ClipToBounds="False">
            <Border Background="#000000"
                    Width="450" Height="450"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="-250,-350,0,0"
                    CornerRadius="450"
                    Opacity="0.8">
                <Border.Effect>
                    <BlurEffect Radius="150" />
                </Border.Effect>
            </Border>
            <Border Background="#000000"
                    Width="350" Height="350"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-300,-200,0"
                    CornerRadius="350"
                    Opacity="0.65">
                <Border.Effect>
                    <BlurEffect Radius="160" />
                </Border.Effect>
            </Border>
            <Border x:Name="HomeBackgroundLayer"
                    Background="#4424d8ff"
                    Width="500" Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,-200"
                    CornerRadius="300"
                    Opacity="0.45">
                <Border.Effect>
                    <BlurEffect Radius="170" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
            </Border>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="600"
                    Height="350"
                    Background="#0000002f"
                    CornerRadius="0"
                    Opacity="0.4">
                <Border.Effect>
                    <BlurEffect Radius="100" />
                </Border.Effect>
            </Border>
            <Panel IsHitTestVisible="False" ClipToBounds="False">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,-250,0,0"
                        Width="250"
                        Height="250"
                        CornerRadius="200"
                        Background="#0df904"
                        Opacity="0.6">
                    <Border.Effect>
                        <BlurEffect Radius="500" />
                    </Border.Effect>
                </Border>
            </Panel>
        </Panel>

        <Grid RowDefinitions="40, *">
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    BorderBrush="#2D2D2D"
                    BorderThickness="0,0,0,1"
                    Padding="10,0"
                    Background="Transparent"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Image Width="20" Height="20" Source="/Assets/radium-icon.png" />
                        <TextBlock Text="Configuration" Foreground="White" VerticalAlignment="Center" FontSize="11"
                                   FontWeight="Medium" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="#888888"
                            FontSize="14"
                            Padding="8,4"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="15" Margin="20, 20, 20, 20">
                    <TextBlock Text="Settings" Foreground="White" FontSize="18" FontWeight="SemiBold" />

                    <CheckBox x:Name="DiscordRPCOption" Content="Discord RPC" IsChecked="False"
                              IsCheckedChanged="DiscordRPCOption_Checked"/>
                    
                    <StackPanel x:Name="UsernameOption" Spacing="5">
                        <TextBlock Text="Radium Username" Foreground="#888888" FontSize="12" />
                        <TextBox x:Name="Usernameopttb" Background="#1A1A1A" Foreground="White" BorderBrush="#2D2D2D"
                                 CornerRadius="4" TextChanged="Username_Changed"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="5">
                        <TextBlock Text="Downloader Thread Count" Foreground="#888888" FontSize="12" />
                        <NumericUpDown x:Name="Threadcountnud" Background="#1A1A1A" BorderBrush="#2D2D2D"
                                       CornerRadius="4" ValueChanged="ThreadCount_Changed" Minimum="1" 
                                       Increment="1" FormatString="F0"/>
                    </StackPanel>

                    <StackPanel x:Name="ProtonOption" Spacing="5" IsVisible="False">
                        <TextBlock Text="Proton Folder (Linux)" Foreground="#888888" FontSize="12" />
                        <TextBox x:Name="Protonpathtb" Background="#1A1A1A" Foreground="White" BorderBrush="#2D2D2D"
                                 CornerRadius="4" TextChanged="ProtonPath_Changed" />
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Steam App Id" Foreground="#888888" FontSize="12" />
                        <TextBox x:Name="Steamappidtb" Background="#1A1A1A" Foreground="White" BorderBrush="#2D2D2D"
                                 CornerRadius="4" TextChanged="SteamAppId_Changed" />
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Launch Options" Foreground="#888888" FontSize="12" />
                        <TextBox x:Name="Launchoptstb" Background="#1A1A1A" Foreground="White" BorderBrush="#2D2D2D"
                                 CornerRadius="4" TextChanged="LaunchOptions_Changed" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Button x:Name="UninstallButton"
                                Content="Uninstall Radium"
                                Click="UninstallButton_Click"
                                Background="#2D2D2D"
                                Foreground="White"
                                CornerRadius="8"
                                Padding="10,8"
                                HorizontalAlignment="Stretch" />
                        <TextBlock Text="Only removes the launcher's Radium installation."
                                   Foreground="#888888" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                    
                    <Expander x:Name="AdvancedOptions" Header="Advanced" IsExpanded="False">
                        <StackPanel Spacing="10" Margin="0,10,0,0">
                            <TextBlock Text="Custom Batch File Paths" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                            <StackPanel Spacing="5">
                                <TextBlock Text="Screen Mode Batch File" Foreground="#888888" FontSize="12" />
                                <TextBox x:Name="ScreenBatchFileTb" Background="#1A1A1A" Foreground="White" BorderBrush="#2D2D2D"
                                         CornerRadius="4" TextChanged="ScreenBatchFile_Changed" />
                            </StackPanel>
                            <StackPanel Spacing="5">
                                <TextBlock Text="VR Mode Batch File" Foreground="#888888" FontSize="12" />
                                <TextBox x:Name="VrBatchFileTb" Background="#1A1A1A" Foreground="White" BorderBrush="#2D2D2D"
                                         CornerRadius="4" TextChanged="VrBatchFile_Changed" />
                            </StackPanel>
                            <TextBlock Text="Enter an absolute or launcher-relative .bat file to use for custom launches. The launcher default install is still preferred." 
                                       Foreground="#888888" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Panel>
</Window>